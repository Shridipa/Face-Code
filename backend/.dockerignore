# Exclude local environment and cache
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
.env
.env.*
!.env.example

# Exclude IDE and system files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Exclude large data/logs that should be handled by volumes or external storage
*.db
*.log
telemetry.log
# metrics.db # Handled by Dockerfile touch and volume

# Exclude other components
frontend/
docker-compose.yml
Dockerfile

# Exclude unnecessary scripts
test_execution.py
test_results.txt
pyrightconfig.json
setup.ps1
start_project.bat
verify_backend.py
test_endpoint.py
