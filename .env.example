# FaceCode API Keys

# --- GROQ API KEY ---
# Required for running the LLM hint system built into the IDE.
# Get yours here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- LEETCODE API URL ---
# Usually defaults to https://leetcode.com/graphql
LEETCODE_URL=https://leetcode.com/graphql
